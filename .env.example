# --- Option A: OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Option B: OpenRouter (keys start with sk-or-...) ---
# Either put your OpenRouter key in OPENAI_API_KEY (auto-detected) or here:
# OPENROUTER_API_KEY=sk-or-...
# The base URL is set automatically for OpenRouter, but you can override it:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Optional: pick the model ---
# For OpenAI:     gpt-4o-mini (default)
# For OpenRouter: openai/gpt-4o-mini (default), or e.g. meta-llama/llama-3.1-8b-instruct
# HEART_DIAGNOSIS_MODEL=openai/gpt-4o-mini
